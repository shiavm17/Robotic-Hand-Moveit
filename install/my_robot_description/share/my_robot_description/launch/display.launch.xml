import os
from pathlib import Path
from launch import LaunchDescription
from launch_ros.substitutions import FindPackageShare
from launch_ros.actions import Node
from launch.substitutions import Command

def generate_launch_description():
    pkg_share = FindPackageShare('my_robot_description').find('my_robot_description')
    urdf_file = os.path.join(pkg_share, 'urdf', 'my_robot.urdf.xacro')
    rviz_file = os.path.join(pkg_share, 'rviz', 'display.rviz')
    
    # Generate robot description using xacro
    robot_desc = Command(['xacro ', urdf_file])
    
    # Robot State Publisher
    rsp_node = Node(
        package='robot_state_publisher',
        executable='robot_state_publisher',
        output='both',
        parameters=[{
            'robot_description': robot_desc,
            'publish_frequency': 50.0,
            'use_sim_time': False,
        }]
    )
    
    # Joint State Publisher GUI
    jsp_gui = Node(
        package='joint_state_publisher_gui',
        executable='joint_state_publisher_gui',
        output='both'
    )
    
    # RViz2
    rviz_node = Node(
        package='rviz2',
        executable='rviz2',
        arguments=['-d', rviz_file],
        output='both'
    )
    
    return LaunchDescription([
        rsp_node,
        jsp_gui,
        rviz_node,
    ])